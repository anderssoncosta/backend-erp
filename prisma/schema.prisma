generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// CORE - MULTI-TENANT FOUNDATION
// ============================================================

model Tenant {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String   @unique
  cnpj        String?  @unique
  email       String?
  phone       String?
  plan        String   @default("STARTER")
  status      String   @default("ACTIVE")
  logoUrl     String?
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  branches          Branch[]
  regions           Region[]
  users             User[]
  permissions       Permission[]
  clients           Client[]
  contracts         Contract[]
  serviceOrders     ServiceOrder[]
  materials         Material[]
  stockItems        StockItem[]
  stockMovements    StockMovement[]
  stockTransfers    StockTransfer[]
  stockAdjustments  StockAdjustment[]
  costCenters       CostCenter[]
  invoices          Invoice[]
  expenses          Expense[]
  revenues          Revenue[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  integrationOutbox IntegrationOutbox[]
  systemSettings    SystemSetting[]
  fieldExecutions   FieldExecution[]
  vehicles          Vehicle[]
  schedules         Schedule[]
  projects          Project[]
  assets            Asset[]
  tickets           Ticket[]
  callRecords       CallRecord[]
  employees         Employee[]
  timeEntries       TimeEntry[]
  safetyDocuments   SafetyDocument[]
  ppeDeliveries     PPEDelivery[]
  incidents         Incident[]
  works             Work[]
  lightingPoints    LightingPoint[]
  lightingOrders    LightingOrder[]

  @@map("tenants")
}

model Branch {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  regionId  String?   @db.Uuid
  name      String
  code      String
  cnpj      String?
  email     String?
  phone     String?
  address   Json?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  region  Region? @relation(fields: [regionId], references: [id])
  users   User[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("branches")
}

model Region {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  name      String
  code      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  branches Branch[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("regions")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @db.Uuid
  branchId      String?   @db.Uuid
  name          String
  email         String
  password      String
  phone         String?
  avatarUrl     String?
  role          String    @default("OPERATOR")
  status        String    @default("ACTIVE")
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  branch         Branch?          @relation(fields: [branchId], references: [id])
  permissions    UserPermission[]
  refreshTokens  RefreshToken[]
  sessions       Session[]
  passwordResets PasswordResetToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Permission {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @db.Uuid
  module   String
  action   String
  label    String?

  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  userPerms   UserPermission[]

  @@unique([tenantId, module, action])
  @@index([tenantId])
  @@map("permissions")
}

model UserPermission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @db.Uuid
  permissionId String   @db.Uuid
  isRevoked    Boolean  @default(false)
  grantedById  String?  @db.Uuid
  grantedAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([userId, permissionId])
  @@index([userId])
  @@map("user_permissions")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  tenantId  String   @db.Uuid
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model Session {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @db.Uuid
  tenantId   String    @db.Uuid
  ipAddress  String?
  userAgent  String?
  device     String?
  isActive   Boolean   @default(true)
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("sessions")
}

model PasswordResetToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([token])
  @@map("password_reset_tokens")
}

// ============================================================
// CLIENTS & CONTRACTS
// ============================================================

model Client {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @db.Uuid
  name       String
  tradeName  String?
  document   String?
  type       String    @default("COMPANY")
  email      String?
  phone      String?
  status     String    @default("ACTIVE")
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  contacts      ClientContact[]
  addresses     ClientAddress[]
  contracts     Contract[]
  serviceOrders ServiceOrder[]

  @@index([tenantId])
  @@map("clients")
}

model ClientContact {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String   @db.Uuid
  name      String
  role      String?
  email     String?
  phone     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@map("client_contacts")
}

model ClientAddress {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId     String   @db.Uuid
  label        String?
  street       String
  number       String?
  complement   String?
  neighborhood String?
  city         String
  state        String
  zipCode      String
  country      String   @default("BR")
  latitude     Decimal? @db.Decimal(10, 8)
  longitude    Decimal? @db.Decimal(11, 8)
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@map("client_addresses")
}

model Contract {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid
  clientId    String    @db.Uuid
  number      String
  title       String
  type        String
  status      String    @default("ACTIVE")
  startDate   DateTime
  endDate     DateTime?
  value       Decimal?  @db.Decimal(15, 2)
  currency    String    @default("BRL")
  slaPolicy   Json?
  terms       String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant        Tenant                @relation(fields: [tenantId], references: [id])
  client        Client                @relation(fields: [clientId], references: [id])
  serviceOrders ServiceOrder[]
  serviceTypes  ContractServiceType[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@map("contracts")
}

// ============================================================
// SERVICE ORDERS
// ============================================================

model ServiceOrder {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @db.Uuid
  branchId     String    @db.Uuid
  clientId     String?   @db.Uuid
  contractId   String?   @db.Uuid
  orderNumber  String
  title        String
  description  String?
  type         String
  status       String    @default("OPEN")
  priority     String    @default("MEDIUM")
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?
  dueDate      DateTime?
  slaDeadline  DateTime?
  slaBreached  Boolean   @default(false)
  address      Json?
  metadata     Json      @default("{}")
  createdById  String    @db.Uuid
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant      Tenant                    @relation(fields: [tenantId], references: [id])
  client      Client?                   @relation(fields: [clientId], references: [id])
  contract    Contract?                 @relation(fields: [contractId], references: [id])
  assignments ServiceOrderAssignment[]
  comments    ServiceOrderComment[]
  attachments ServiceOrderAttachment[]
  history     ServiceOrderHistory[]
  materials   ServiceOrderMaterial[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, branchId])
  @@index([tenantId, slaBreached])
  @@map("service_orders")
}

model ServiceOrderAssignment {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceOrderId String    @db.Uuid
  userId         String    @db.Uuid
  assignedById   String    @db.Uuid
  assignedAt     DateTime  @default(now())
  unassignedAt   DateTime?
  isActive       Boolean   @default(true)

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  @@index([serviceOrderId])
  @@index([userId])
  @@map("service_order_assignments")
}

model ServiceOrderComment {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceOrderId String    @db.Uuid
  authorId       String    @db.Uuid
  content        String
  isInternal     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  @@index([serviceOrderId])
  @@map("service_order_comments")
}

model ServiceOrderAttachment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceOrderId String   @db.Uuid
  uploadedById   String   @db.Uuid
  fileName       String
  originalName   String
  mimeType       String
  size           Int
  s3Key          String
  s3Bucket       String
  url            String?
  createdAt      DateTime @default(now())

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  @@index([serviceOrderId])
  @@map("service_order_attachments")
}

model ServiceOrderHistory {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceOrderId String   @db.Uuid
  actorId        String   @db.Uuid
  action         String
  fromValue      String?
  toValue        String?
  metadata       Json?
  createdAt      DateTime @default(now())

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  @@index([serviceOrderId])
  @@map("service_order_history")
}

model ServiceOrderMaterial {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceOrderId String   @db.Uuid
  materialId     String   @db.Uuid
  quantity       Decimal  @db.Decimal(10, 3)
  unitCost       Decimal  @db.Decimal(15, 4)
  totalCost      Decimal  @db.Decimal(15, 4)
  registeredById String   @db.Uuid
  createdAt      DateTime @default(now())

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  @@index([serviceOrderId])
  @@map("service_order_materials")
}

// ============================================================
// INVENTORY
// ============================================================

model MaterialGroup {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  name      String
  code      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  materials Material[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("material_groups")
}

model Material {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid
  groupId     String?   @db.Uuid
  code        String
  name        String
  description String?
  unit        String    @default("UN")
  minStock    Decimal?  @db.Decimal(10, 3)
  maxStock    Decimal?  @db.Decimal(10, 3)
  costPrice   Decimal?  @db.Decimal(15, 4)
  isActive    Boolean   @default(true)
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  group      MaterialGroup? @relation(fields: [groupId], references: [id])
  stockItems StockItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("materials")
}

model StockItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  branchId     String   @db.Uuid
  materialId   String   @db.Uuid
  quantity     Decimal  @default(0) @db.Decimal(10, 3)
  reservedQty  Decimal  @default(0) @db.Decimal(10, 3)
  availableQty Decimal  @default(0) @db.Decimal(10, 3)
  averageCost  Decimal  @default(0) @db.Decimal(15, 4)
  location     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  material Material @relation(fields: [materialId], references: [id])

  @@unique([tenantId, branchId, materialId])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@map("stock_items")
}

model StockMovement {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid
  branchId      String   @db.Uuid
  materialId    String   @db.Uuid
  type          String
  quantity      Decimal  @db.Decimal(10, 3)
  unitCost      Decimal  @db.Decimal(15, 4)
  totalCost     Decimal  @db.Decimal(15, 4)
  balanceBefore Decimal  @db.Decimal(10, 3)
  balanceAfter  Decimal  @db.Decimal(10, 3)
  referenceType String?
  referenceId   String?  @db.Uuid
  batchNumber   String?
  notes         String?
  performedById String   @db.Uuid
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, materialId])
  @@index([tenantId, branchId])
  @@index([referenceType, referenceId])
  @@map("stock_movements")
}

model StockTransfer {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @db.Uuid
  transferNumber  String
  fromBranchId    String    @db.Uuid
  toBranchId      String    @db.Uuid
  status          String    @default("PENDING")
  requestedById   String    @db.Uuid
  approvedById    String?   @db.Uuid
  completedById   String?   @db.Uuid
  approvedAt      DateTime?
  completedAt     DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant              @relation(fields: [tenantId], references: [id])
  items  StockTransferItem[]

  @@unique([tenantId, transferNumber])
  @@index([tenantId])
  @@map("stock_transfers")
}

model StockTransferItem {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transferId   String  @db.Uuid
  materialId   String  @db.Uuid
  requestedQty Decimal @db.Decimal(10, 3)
  approvedQty  Decimal @db.Decimal(10, 3)
  sentQty      Decimal @db.Decimal(10, 3)
  receivedQty  Decimal @db.Decimal(10, 3)
  unitCost     Decimal @db.Decimal(15, 4)

  transfer StockTransfer @relation(fields: [transferId], references: [id])

  @@index([transferId])
  @@map("stock_transfer_items")
}

model StockAdjustment {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @db.Uuid
  branchId     String    @db.Uuid
  materialId   String    @db.Uuid
  type         String
  quantityBefore Decimal @db.Decimal(10, 3)
  quantityAfter  Decimal @db.Decimal(10, 3)
  difference     Decimal @db.Decimal(10, 3)
  reason       String
  status       String    @default("PENDING")
  requestedById String   @db.Uuid
  approvedById  String?  @db.Uuid
  approvedAt    DateTime?
  rejectedAt    DateTime?
  rejectionReason String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, branchId])
  @@map("stock_adjustments")
}

// ============================================================
// FINANCIAL
// ============================================================

model CostCenter {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  branchId  String?   @db.Uuid
  code      String
  name      String
  type      String    @default("OPERATIONAL")
  parentId  String?   @db.Uuid
  budget    Decimal?  @db.Decimal(15, 2)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant   Tenant      @relation(fields: [tenantId], references: [id])
  parent   CostCenter? @relation("CostCenterHierarchy", fields: [parentId], references: [id])
  children CostCenter[] @relation("CostCenterHierarchy")
  expenses Expense[]
  invoices Invoice[]
  revenues Revenue[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("cost_centers")
}

model Invoice {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @db.Uuid
  branchId       String?   @db.Uuid
  costCenterId   String?   @db.Uuid
  clientId       String?   @db.Uuid
  contractId     String?   @db.Uuid
  invoiceNumber  String
  referenceMonth String?
  status         String    @default("DRAFT")
  type           String
  issueDate      DateTime  @default(now())
  dueDate        DateTime
  paidDate       DateTime?
  subtotal       Decimal   @db.Decimal(15, 2)
  taxAmount      Decimal   @default(0) @db.Decimal(15, 2)
  discountAmount Decimal   @default(0) @db.Decimal(15, 2)
  totalAmount    Decimal   @db.Decimal(15, 2)
  paidAmount     Decimal   @default(0) @db.Decimal(15, 2)
  currency       String    @default("BRL")
  notes          String?
  createdById    String    @db.Uuid
  cancelReason   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  costCenter CostCenter? @relation(fields: [costCenterId], references: [id])
  items      InvoiceItem[]
  payments   Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@map("invoices")
}

model InvoiceItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId      String   @db.Uuid
  tenantId       String   @db.Uuid
  serviceOrderId String?  @db.Uuid
  description    String
  quantity       Decimal  @db.Decimal(10, 3)
  unitPrice      Decimal  @db.Decimal(15, 4)
  discount       Decimal  @default(0) @db.Decimal(5, 2)
  total          Decimal  @db.Decimal(15, 4)
  createdAt      DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId     String   @db.Uuid
  tenantId      String   @db.Uuid
  amount        Decimal  @db.Decimal(15, 2)
  method        String
  paidAt        DateTime
  reference     String?
  notes         String?
  registeredById String  @db.Uuid
  createdAt     DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("payments")
}

model Expense {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @db.Uuid
  branchId       String?   @db.Uuid
  costCenterId   String?   @db.Uuid
  serviceOrderId String?   @db.Uuid
  category       String
  description    String
  amount         Decimal   @db.Decimal(15, 2)
  currency       String    @default("BRL")
  competenceDate DateTime
  status         String    @default("PENDING")
  approvedById   String?   @db.Uuid
  approvedAt     DateTime?
  rejectedAt     DateTime?
  rejectionReason String?
  paidAt         DateTime?
  attachmentUrl  String?
  notes          String?
  requestedById  String    @db.Uuid
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  costCenter CostCenter? @relation(fields: [costCenterId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, costCenterId])
  @@map("expenses")
}

model Revenue {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @db.Uuid
  branchId       String?  @db.Uuid
  costCenterId   String?  @db.Uuid
  category       String
  description    String
  amount         Decimal  @db.Decimal(15, 2)
  currency       String   @default("BRL")
  competenceDate DateTime
  referenceId    String?  @db.Uuid
  referenceType  String?
  notes          String?
  createdById    String   @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  costCenter CostCenter? @relation(fields: [costCenterId], references: [id])

  @@index([tenantId])
  @@index([tenantId, competenceDate])
  @@map("revenues")
}

// ============================================================
// AUDIT & NOTIFICATIONS
// ============================================================

model AuditLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid
  userId        String?  @db.Uuid
  module        String
  action        String
  entityType    String
  entityId      String?
  ipAddress     String?
  userAgent     String?
  correlationId String?
  before        Json?
  after         Json?
  metadata      Json?
  severity      String   @default("INFO")
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, module])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, userId])
  @@map("audit_logs")
}

model Notification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @db.Uuid
  userId     String    @db.Uuid
  type       String
  title      String
  body       String
  data       Json?
  channel    String    @default("IN_APP")
  isRead     Boolean   @default(false)
